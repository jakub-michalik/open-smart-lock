# openMatterSmartLock — top-level Kconfig

mainmenu "openMatterSmartLock"

menu "Actuator driver"

rsource "drivers/actuator/servo_pwm/Kconfig"

endmenu

menu "Feedback driver"

rsource "drivers/feedback/adc_potentiometer/Kconfig"

endmenu

menu "Power gate driver"

rsource "drivers/power/gpio_gate/Kconfig"

endmenu

config OMSL_HEARTBEAT_INTERVAL_MS
    int "Heartbeat interval (ms)"
    default 5000

config OMSL_SERVO_TIMEOUT_MS
    int "Servo actuation timeout (ms)"
    default 1500

config OMSL_FACTORY_RESET_HOLD_TIME_MS
    int "Hold time on action button for factory reset (ms)"
    default 10000

config LOCK_SCHEDULES
    bool "Support user week-day and year-day schedules"
    default n

menu "Memory tuning (advanced)"

config OMSL_HEAP_HEADROOM_PCT
    int "Reserved heap headroom percentage"
    default 15

config OMSL_LOG_HEARTBEAT_STACKS
    bool "Log stack high-water marks on each heartbeat"
    default n

endmenu

# NCS Matter sample-common support and CHIP module integration.
# These provide CONFIG_NCS_SAMPLE_MATTER_* and CHIP defaults.
source "${ZEPHYR_CONNECTEDHOMEIP_MODULE_DIR}/config/nrfconnect/chip-module/Kconfig.features"
source "${ZEPHYR_CONNECTEDHOMEIP_MODULE_DIR}/config/nrfconnect/chip-module/Kconfig.defaults"
source "${ZEPHYR_NRF_MODULE_DIR}/samples/matter/common/src/Kconfig"

source "Kconfig.zephyr"
